{
    "services": {
        "frontend": {
            "root": "frontend/",
            "framework": "nextjs"
        },
        "backend": {
            "root": ".",
            "framework": "fastapi",
            "entrypoint": "backend.main:app",
            "functions": {
                "backend.main:app": {
                    "includeFiles": "blueprint_core/**",
                    "excludeFiles": "{frontend/**,rust/**,docs/**,tests/**,benchmarks/**,examples/**,scripts/**,dist/**,tmp/**,.logs/**,.spacebase/**,.vscode/**,supabase/**,*.db,*.log,__pycache__/**,**/__pycache__/**,**/*.pyc,**/*.pyo,**/*.tsbuildinfo}"
                },
                "backend/main.py": {
                    "includeFiles": "blueprint_core/**",
                    "excludeFiles": "{frontend/**,rust/**,docs/**,tests/**,benchmarks/**,examples/**,scripts/**,dist/**,tmp/**,.logs/**,.spacebase/**,.vscode/**,supabase/**,*.db,*.log,__pycache__/**,**/__pycache__/**,**/*.pyc,**/*.pyo,**/*.tsbuildinfo}"
                },
                "main.py": {
                    "includeFiles": "blueprint_core/**",
                    "excludeFiles": "{frontend/**,rust/**,docs/**,tests/**,benchmarks/**,examples/**,scripts/**,dist/**,tmp/**,.logs/**,.spacebase/**,.vscode/**,supabase/**,*.db,*.log,__pycache__/**,**/__pycache__/**,**/*.pyc,**/*.pyo,**/*.tsbuildinfo}"
                }
            }
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": {
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "service": "frontend"
            }
        }
    ]
}
