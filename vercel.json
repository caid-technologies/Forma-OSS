{
    "services": {
        "frontend": {
            "root": "frontend/",
            "framework": "nextjs"
        },
        "backend": {
            "root": ".",
            "framework": "fastapi",
            "entrypoint": "backend.main:app",
            "installCommand": "python -m pip install . -r backend/requirements.txt"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": {
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "service": "frontend"
            }
        }
    ]
}
